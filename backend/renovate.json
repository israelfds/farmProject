{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:base",
        ":semanticCommits",
        ":semanticCommitTypeAll(chore)",
        ":semanticCommitScope(deps)"
    ],
    "schedule": [
        "before 4am on monday"
    ],
    "timezone": "America/Sao_Paulo",
    "packageRules": [
        {
            "matchUpdateTypes": [
                "minor",
                "patch"
            ],
            "matchCurrentVersion": "!/^0/",
            "automerge": true
        },
        {
            "matchPackageNames": [
                "@nestjs/*"
            ],
            "matchUpdateTypes": [
                "major"
            ],
            "enabled": false
        },
        {
            "matchPackageNames": [
                "typeorm"
            ],
            "matchUpdateTypes": [
                "major"
            ],
            "enabled": false
        },
        {
            "matchPackageNames": [
                "typescript"
            ],
            "matchUpdateTypes": [
                "major"
            ],
            "enabled": false
        }
    ],
    "assignees": [
        "farm-project-team"
    ],
    "reviewers": [
        "farm-project-team"
    ],
    "labels": [
        "dependencies",
        "renovate"
    ],
    "commitMessagePrefix": "chore(deps):",
    "commitMessageAction": "update",
    "commitMessageTopic": "{{depName}}",
    "commitMessageExtra": "to {{newVersion}}",
    "prHourlyLimit": 2,
    "prConcurrentLimit": 10,
    "rangeStrategy": "bump",
    "bumpVersion": null,
    "semanticCommits": "enabled",
    "semanticCommitType": "chore",
    "semanticCommitScope": "deps"
}